{
  "hooks": {
    "SessionStart": [
      { "matcher": "", "hooks": [ { "type": "command", "command": "pwsh -NoProfile -File ${CLAUDE_PLUGIN_ROOT}/scripts/session-context.ps1", "timeout": 15 } ] }
    ],
    "PreToolUse": [
      { "matcher": "Bash", "hooks": [ { "type": "command", "command": "pwsh -NoProfile -File ${CLAUDE_PLUGIN_ROOT}/scripts/guard-bash.ps1", "timeout": 15 } ] }
    ],
    "Stop": [
      { "matcher": "", "hooks": [ { "type": "command", "command": "pwsh -NoProfile -File ${CLAUDE_PLUGIN_ROOT}/scripts/run-verify.ps1", "timeout": 600 } ] }
    ]
  }
}
